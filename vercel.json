{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/onboarding/scrape/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/campaign/approve/[token]/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/retry-writebacks/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/retry-writebacks",
      "schedule": "*/5 * * * *"
    }
  ]
}
