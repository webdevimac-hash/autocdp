# ============================================================
# AutoCDP — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# --- Supabase (Required) ---
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhb...your-service-role-key

# --- Anthropic (Required for AI features) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...your-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Direct Mail: PostGrid (Required for mail features) ---
# Sign up at: https://postgrid.com → Dashboard → API Keys
# Use a test key (test_sk_...) for local dev — no mail is actually sent
# Use a live key (live_sk_...) for production
POSTGRID_API_KEY=test_sk_...your-postgrid-key
POSTGRID_WEBHOOK_SECRET=your-postgrid-webhook-secret

# --- Billing: Stripe (Phase 2) ---
# Base fee + usage metering via Stripe Billing / Orb
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Orb (usage-based billing) — optional alternative to Stripe metering
ORB_API_KEY=

# --- SMS Provider (Phase 2) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Email Provider (Phase 2) ---
RESEND_API_KEY=
# Resend webhook signing secret — set in Resend Dashboard → Webhooks
# Receives email.delivered, email.opened, email.clicked, email.bounced events
RESEND_WEBHOOK_SECRET=

# --- DMS: CDK Fortellis ---
# Register at: https://developer.fortellis.io → My Apps → Create App
# Set redirect URI to: https://your-domain.com/api/integrations/cdk/callback
CDK_FORTELLIS_CLIENT_ID=
CDK_FORTELLIS_CLIENT_SECRET=
# Optional: verify CDK webhook payloads
CDK_FORTELLIS_WEBHOOK_SECRET=

# --- DMS: Reynolds & Reynolds ---
# API base — override if Reynolds provides a different endpoint in your contract
REYNOLDS_API_BASE=https://api.reyrey.net/v1

# --- Token Encryption ---
# 64 hex characters (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER change this key after tokens are stored — they will become unreadable
ENCRYPTION_KEY=

# --- Internal ---
BILLING_WEBHOOK_SECRET=your-internal-webhook-secret
